{
  "name": "functions",
  "private": true,
  "description": "Mom Bucks Cloud Functions (TypeScript)",
  "main": "lib/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "lint": "eslint --ext .ts src test",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "test:unit": "vitest run --exclude 'test/rules/**'",
    "test:rules": "../scripts/run-rules-tests.sh",
    "test": "npm run test:unit && npm run test:rules",
    "test:watch": "vitest --exclude 'test/rules/**'",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "backfill": "tsx src/backfill/cli.ts"
  },
  "dependencies": {
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^6.0.1"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "@types/node": "^22.5.0",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "firebase": "^11.0.0",
    "firebase-functions-test": "^3.3.0",
    "pg": "^8.13.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
