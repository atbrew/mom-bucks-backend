rules_version = '2';

// Real parentUids membership model ‚Äî Phase 2, issue #10.
//
// Replaces the Phase 0 deny-all baseline. Source of truth for the
// prose version: docs/schema.md ‚Üí "Security model (prose)".
//
// Principles:
//   - There is no `family` collection. Children carry `parentUids: string[]`.
//   - `users/{uid}` is strictly self-scoped.
//   - Children and everything under them are gated on
//     `request.auth.uid in <child>.parentUids`.
//   - `parentUids` itself can ONLY be mutated by server-side callables
//     (acceptInvite #13, removeParentFromChildren #14) via the Admin
//     SDK, which bypasses these rules. Clients cannot touch it.
//   - Invites are readable by anyone who knows the token (the token is
//     the secret). They can be created by authenticated users but not
//     directly updated ‚Äî acceptance goes through the #13 callable.
//
// The Phase 0 `hello/` escape hatch is gone: the deployed helloWorld
// function writes via Admin SDK, which bypasses rules, so the
// collection doesn't need a rule at all and is covered by the
// default-deny.

service cloud.firestore {
  match /databases/{database}/documents {

    // ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
    // helpers
    // ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // The canonical "am I a parent of this child?" check.
    // Reads the child doc once; the result is cached for the duration
    // of a single rule evaluation so subcollection reads don't pay for
    // it twice.
    function isChildParent(childId) {
      return isSignedIn()
          && request.auth.uid in
             get(/databases/$(database)/documents/children/$(childId)).data.parentUids;
    }

    // True iff an update leaves `parentUids` exactly as it was.
    // Used to ban client-side mutations of membership; those must go
    // through the acceptInvite / removeParentFromChildren callables.
    function parentUidsUnchanged() {
      return !(request.resource.data.diff(resource.data).affectedKeys()
                .hasAny(['parentUids']));
    }

    // True iff an update leaves `createdAt` exactly as it was.
    // The creation instant is historical and must never be
    // re-stamped, nulled, or retyped
    // by a client. Even a `serverTimestamp()` write on UPDATE is
    // refused here ‚Äî that would let a parent silently bump an old
    // doc's "createdAt" to today and corrupt the historical
    // ordering. Clients write `createdAt` exactly once, at create
    // time, via `serverTimestamp()` ‚Äî see the collection create
    // rules below. Used by children, transactions, and
    // vaultTransactions.
    function createdAtUnchanged() {
      return !(request.resource.data.diff(resource.data).affectedKeys()
                .hasAny(['createdAt']));
    }

    // True iff an update leaves `createdByUid` exactly as it was.
    // `createdByUid` is an audit-only field ‚Äî it records who
    // originally created the doc. A post-create mutation would
    // silently rewrite history; block it. Used by children and
    // transactions (vaultTransactions has no createdByUid field).
    // PR #32 review feedback.
    function createdByUidUnchanged() {
      return !(request.resource.data.diff(resource.data).affectedKeys()
                .hasAny(['createdByUid']));
    }

    // True iff an update to a transaction or vaultTransaction
    // leaves the three ledger-core fields `amount`, `type`, and
    // `createdByUid` untouched. Ledger rows are write-once by
    // design: `onTransactionCreate` (#15) consumes `amount` and
    // `type` exactly once when computing the new child balance,
    // so a subsequent client mutation would silently desync
    // `child.balance` from the ledger. `createdByUid` is audit-
    // only. Applied on the update path for both the main and
    // vault ledgers.
    //
    // Note: vaultTransactions have no `createdByUid` field (see
    // `FirestoreVaultTransaction` in `functions/src/backfill/transform.ts`),
    // so including the key in the affectedKeys check there is
    // effectively a no-op ‚Äî the emulator reports `affectedKeys`
    // only for keys that actually appear in the before or after
    // document, which `createdByUid` does not. Sharing one helper
    // across both collections keeps the rule file small without
    // changing semantics. PR #32 review feedback.
    function txnCoreUnchanged() {
      return !(request.resource.data.diff(resource.data).affectedKeys()
                .hasAny(['amount', 'type', 'createdByUid', 'source']));
    }

    // True iff the incoming `createdAt` is a server-resolved
    // timestamp ‚Äî i.e. the client wrote `serverTimestamp()`, which
    // the rules engine sees as `request.time`. Any other shape
    // (missing, string, client-chosen Date) fails the comparison.
    //
    // Shared by children, transactions, and vaultTransactions. The
    // point is uniform "no client-chosen creation timestamps" across
    // every server-authoritative collection ‚Äî clocks drift, and
    // backdated ledger entries would corrupt analytics and audit
    // trails.
    function createdAtValidOnCreate() {
      return request.resource.data.createdAt is timestamp
          && request.resource.data.createdAt == request.time;
    }

    // True iff an update leaves `allowanceId` exactly as it was.
    // `allowanceId` is the "at most one ALLOWANCE activity per
    // child" pointer ‚Äî it only ever moves via the `createActivity`
    // / `deleteActivity` callables (Admin SDK, bypasses rules).
    // Direct client writes must not touch it, otherwise a client
    // could forge a stale activityId and break the uniqueness
    // invariant downstream.
    //
    // Uses `diff().affectedKeys()` for two reasons: (1) consistency
    // with the other "pin this key" helpers above
    // (`parentUidsUnchanged`, `createdAtUnchanged`,
    // `createdByUidUnchanged`, `txnCoreUnchanged`); and (2)
    // direct access (`resource.data.allowanceId`) would error out
    // on any legacy doc where the field is missing, blocking even
    // innocuous updates like a name change. affectedKeys() treats
    // missing-before/missing-after as "not affected" so the rule
    // stays open on unrelated edits.
    function allowanceIdUnchanged() {
      return !(request.resource.data.diff(resource.data).affectedKeys()
                .hasAny(['allowanceId']));
    }

    // True iff an update leaves the `vault` map exactly as it was.
    // The whole nested map ‚Äî balance, target, interest/matching
    // sub-objects, unlockedAt ‚Äî is Admin-SDK-managed via the vault
    // callables (`depositToVault`, `claimInterest`, `unlockVault`)
    // and `mb vault configure`. A direct client write could silently
    // desync vault.balance from the vaultTransactions ledger, or
    // flip unlockedAt/weeklyRate to forge interest payouts.
    //
    // Deep equality ‚Äî not `affectedKeys().hasAny(['vault'])` ‚Äî
    // because a client could issue a nested field-path update
    // (`updateDoc(ref, 'vault.balance', 999)`) whose affectedKeys
    // would read `vault.balance`, not `vault`, and slip past a
    // top-level key check. Comparing the pre- and post-write map
    // values catches both whole-map replacement and nested-path
    // mutation.
    //
    // Uses `.get('vault', null)` on both sides instead of direct
    // `resource.data.vault` access. Direct access errors out on
    // any doc where the field is missing ‚Äî which would block
    // unrelated name/balance updates on legacy records that
    // predate the schema refresh. Defaulting missing-to-null keeps
    // the equality check valid: missing == missing passes,
    // missing ‚Üí non-null correctly fails (the client must not
    // materialise a vault map without going through the
    // Admin-SDK callables).
    function vaultUnchanged() {
      return request.resource.data.get('vault', null) ==
             resource.data.get('vault', null);
    }

    // ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
    // users/{uid}
    // ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
    //
    // A user doc is created on first sign-in by the client itself (the
    // doc ID must match the caller's Firebase Auth uid). Only the
    // owning user can read or write it ‚Äî nobody else ever touches it.
    match /users/{uid} {
      allow read, write: if isSelf(uid);
    }

    // ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
    // children/{childId}
    // ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
    //
    // The unit of access. Security rests entirely on the
    // `parentUids: string[]` field.
    match /children/{childId} {

      // READ ‚Äî any parent in the array can read the child doc.
      allow read: if isSignedIn()
                  && request.auth.uid in resource.data.parentUids;

      // CREATE ‚Äî the caller creates the child with ONLY their own uid
      // in `parentUids`. Every subsequent co-parent must be added via
      // the acceptInvite (#13) callable. This closes a loophole where
      // a client could otherwise seed `parentUids: [me, victim]` at
      // creation time and grant access to an unrelated user without
      // going through the invite flow.
      //
      // `dateOfBirth` is required and must be a `timestamp`. It
      // mirrors the Flask `Child.date_of_birth` column
      // (`db.Date, nullable=False`) ‚Äî a child cannot be created
      // without one. The field is pinned at the rules layer so
      // neither the Phase 2 backfill nor any future client writer
      // can silently drop it.
      //
      // `createdAt` is required and must equal `request.time`.
      // Clients write it exactly once, at create time, by sending
      // `serverTimestamp()` ‚Äî which the server resolves to
      // `request.time` during rule evaluation. This closes the
      // door on client-chosen / backdated creation timestamps
      // (whether from clock drift or deliberate forgery) and
      // guarantees the historical ordering of new children is
      // server-authoritative. The Admin-SDK backfill path bypasses
      // rules and carries the Postgres `created_at` through
      // verbatim; see `functions/src/backfill/transform.ts`.
      // On update, `createdAtUnchanged()` (below) refuses any
      // mutation to the field ‚Äî including a fresh serverTimestamp()
      // re-stamp.
      //
      // `createdByUid` must equal the caller's own uid. Audit
      // integrity: without this guard a signed-in parent could
      // create a child stamped `createdByUid: 'someone_else'` and
      // silently forge the audit trail. On update,
      // `createdByUidUnchanged()` (below) pins it so the original
      // creator identity can never be overwritten after the fact.
      // PR #32 review feedback.
      //
      // `allowanceId` must be `null` on create. The pointer is
      // managed by `createActivity` / `deleteActivity` callables
      // (Admin SDK) ‚Äî letting a client seed a non-null activityId
      // at child-create time would break the "at most one
      // ALLOWANCE per child" uniqueness invariant before any
      // activity even exists.
      //
      // `vault` must be `null` on create. Vault config is
      // written atomically by `mb vault configure` (Admin SDK)
      // or the forthcoming `configureVault` callable ‚Äî clients
      // cannot seed a vault map at child-create time, because
      // any non-null shape they write would immediately diverge
      // from the vaultTransactions ledger (balance, interest
      // clock, etc. all have invariants the callables own).
      // `keys().hasAll(['allowanceId', 'vault'])` is load-bearing
      // on top of the `== null` checks: without explicit
      // key-presence, a client could omit either field entirely
      // and the `... == null` comparison on a missing key still
      // evaluates to true (rules treat missing fields as null
      // in equality expressions, not as a type error). Explicit
      // key-presence forces the client to stamp both fields to
      // null on create, so a later `allowanceIdUnchanged()` /
      // `vaultUnchanged()` check on update has a stable
      // pre-state to diff against.
      allow create: if isSignedIn()
                    && request.resource.data.parentUids is list
                    && request.resource.data.parentUids.size() == 1
                    && request.resource.data.parentUids[0] == request.auth.uid
                    && request.resource.data.createdByUid == request.auth.uid
                    && request.resource.data.dateOfBirth is timestamp
                    && request.resource.data.keys().hasAll(['allowanceId', 'vault'])
                    && request.resource.data.allowanceId == null
                    && request.resource.data.vault == null
                    && createdAtValidOnCreate();

      // UPDATE ‚Äî any current parent can update the child, BUT cannot
      // directly mutate `parentUids`, cannot touch `createdAt`, and
      // cannot touch `createdByUid`. `dateOfBirth` IS editable
      // (typos at create time are common, and the field is a product-
      // level editable), but any update must still carry a valid
      // timestamp so the "required + typed" invariant cannot be
      // silently rotted by stripping the field or changing it to a
      // non-timestamp. See `createdAtUnchanged()` and
      // `createdByUidUnchanged()` above for the immutable-field
      // rationale. Membership changes go through the acceptInvite
      // (#13) / removeParentFromChildren (#14) callables.
      //
      // `allowanceId` and the whole `vault` map are also pinned on
      // update (`allowanceIdUnchanged()`, `vaultUnchanged()`).
      // Movement for those fields is owned by the activity / vault
      // callables (Admin SDK, bypasses rules); a client-direct
      // change would either desync `children.allowanceId` from the
      // activities collection or desync `vault.balance` from the
      // vaultTransactions ledger.
      allow update: if isSignedIn()
                    && request.auth.uid in resource.data.parentUids
                    && parentUidsUnchanged()
                    && request.resource.data.dateOfBirth is timestamp
                    && createdAtUnchanged()
                    && createdByUidUnchanged()
                    && allowanceIdUnchanged()
                    && vaultUnchanged();

      // DELETE ‚Äî any current parent can delete the child.
      //
      // Intentionally permissive: hard deletion is how children
      // actually get removed (soft-delete via `deletedAt` is an
      // escape hatch; `onChildDelete` (#16) cascades subcollections).
      // The "last parent standing" guard lives in
      // removeParentFromChildren (#14), not here ‚Äî direct deletes by a
      // current parent are a supported recovery path.
      allow delete: if isSignedIn()
                    && request.auth.uid in resource.data.parentUids;

      // ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
      // children/{childId}/transactions/{txnId}
      // ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
      //
      // READ / UPDATE / DELETE are any-parent. CREATE carries three
      // guards:
      //
      //   1. Shape: `amount` must be a non-negative number. Without
      //      this the overspend check is meaningless ‚Äî a client
      //      could send `{amount: -100, type: 'WITHDRAW'}` and the
      //      `amount <= balance` test is trivially true for any
      //      non-negative balance. `onTransactionCreate` (#15) does
      //      reject negative amounts defensively, but by then the
      //      doc has already landed in the subcollection, leaving
      //      an orphan record with no balance effect.
      //
      //   2. Overspend: a WITHDRAW whose `amount` exceeds the parent
      //      child's current `balance` is rejected synchronously at
      //      write time.
      //
      //   3. `createdAt` must be a server-resolved timestamp
      //      (`createdAtValidOnCreate()`). Clients have to write
      //      `serverTimestamp()` ‚Äî any client-chosen Date or string
      //      is refused. This prevents clock-drift and deliberate
      //      backdating from corrupting the ledger's audit trail.
      //      On UPDATE, `createdAtUnchanged()` keeps the same field
      //      immutable so the same parent who wrote the txn cannot
      //      silently re-stamp it later.
      //
      // Why the amount / overspend checks live in rules and not the
      // trigger: the trigger fires AFTER the doc has been written,
      // so it cannot un-do the write ‚Äî the best it can do is clamp
      // the resulting balance at zero and log. Enforcing at the
      // rules layer is the only place we can refuse the transaction
      // synchronously. The trigger's clamp-at-zero path remains as
      // defense-in-depth (Admin-SDK writers bypass rules, and
      // concurrent WITHDRAWs could still race).
      match /transactions/{txnId} {
        allow read, delete: if isChildParent(childId);

        // `source` is a server-only audit tag (ACTIVITY /
        // VAULT_UNLOCK / VAULT_DEPOSIT) that doubles as the
        // `onTransactionCreate` "don't re-apply" signal. Client-path
        // writes MUST NOT set it ‚Äî the callables that need it run
        // through the Admin SDK and bypass rules. Forbidding the
        // field here prevents a parent from minting a free LODGE by
        // tagging it as though a callable had written it.
        allow create: if isChildParent(childId)
                      && request.resource.data.amount is number
                      && request.resource.data.amount >= 0
                      && !('source' in request.resource.data)
                      && (
                           request.resource.data.type != 'WITHDRAW'
                           || request.resource.data.amount <=
                              get(/databases/$(database)/documents/children/$(childId)).data.balance
                         )
                      && createdAtValidOnCreate();

        // Updates are still allowed so parents can correct a typo
        // in `description` or tag a row after the fact, but the
        // three ledger-core fields (`amount`, `type`,
        // `createdByUid`) plus `createdAt` are pinned immutable.
        // See `txnCoreUnchanged()` and `createdAtUnchanged()` above
        // for the rationale ‚Äî the short version is that
        // `onTransactionCreate` consumes `amount` and `type`
        // exactly once on create to bump `child.balance`, so any
        // subsequent client mutation would silently desync the
        // derived balance from the stored ledger.
        allow update: if isChildParent(childId)
                      && createdAtUnchanged()
                      && txnCoreUnchanged();
      }

      // ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
      // children/{childId}/vaultTransactions/{id}
      // ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
      //
      // Same story as the main transactions collection: the vault
      // ledger drives `vault.balance`, interest, and unlocks, so a
      // forged or backdated `createdAt` ‚Äî or a post-create
      // mutation of `amount` or `type` ‚Äî would corrupt the audit
      // trail and any time-based queries. Split the old `read,
      // write` rule into explicit create / update / delete so we
      // can pin `createdAt` on create and make the ledger-core
      // fields immutable on update.
      //
      // Shape hardening mirrors the main transactions create rule:
      // `amount` must be a non-negative number and `type` must be
      // one of the four `FirestoreVaultTransaction` enum values.
      // Without these a client could seed `{amount: -1000, type:
      // 'GARBAGE'}` and land a row no downstream consumer
      // (balance derivation, interest, unlocks) knows how to
      // handle.
      match /vaultTransactions/{vaultTxnId} {
        allow read, delete: if isChildParent(childId);

        allow create: if isChildParent(childId)
                      && request.resource.data.amount is number
                      && request.resource.data.amount >= 0
                      && request.resource.data.type in
                         ['DEPOSIT', 'UNLOCK', 'INTEREST_CLAIM', 'MATCH']
                      && createdAtValidOnCreate();

        allow update: if isChildParent(childId)
                      && createdAtUnchanged()
                      && txnCoreUnchanged();
      }

      // ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
      // children/{childId}/activities/{activityId}
      // ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
      //
      // Reads are any-parent (same as everywhere else under
      // children). All writes are denied for direct clients ‚Äî
      // activities mutate via four callables:
      //
      //   create ‚Üí createActivity  (stamps nextClaimAt = now; for
      //                             type: 'ALLOWANCE', transactionally
      //                             sets `children.allowanceId` and
      //                             rejects if already set)
      //   update ‚Üí updateActivity  (title / reward / schedule only;
      //                             schedule edits recompute
      //                             nextClaimAt atomically)
      //   claim  ‚Üí claimActivity   (writes a main-ledger `EARN` row,
      //                             bumps `child.balance`, and
      //                             advances `nextClaimAt` ‚Äî all in
      //                             one transaction)
      //   delete ‚Üí deleteActivity  (clears `children.allowanceId`
      //                             when deleting an allowance)
      //
      // The deny-direct-writes posture is load-bearing: every
      // activity mutation has to pair the activity-doc write with
      // a sibling write (`allowanceId` pointer, main ledger row,
      // `nextClaimAt` recompute). Rules can't compose those
      // multi-doc writes atomically; a transactional callable can.
      // Denying client writes forces all paths through the
      // callable-owned atomicity guarantees.
      match /activities/{activityId} {
        allow read: if isChildParent(childId);
        allow create, update, delete: if false;
      }
    }

    // ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
    // invites/{token}
    // ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
    //
    // Invites are the co-parenting enrolment mechanism. The token in
    // the document ID is the secret ‚Äî anyone who knows it can read
    // the invite in order to accept it. Acceptance happens through the
    // acceptInvite (#13) callable which uses the Admin SDK and
    // bypasses these rules.
    //
    // IMPORTANT: the acceptInvite callable MUST re-verify at runtime
    // that the inviter (`invitedByUid`) is STILL in `parentUids` of
    // the child at acceptance time. Rules cannot enforce that ‚Äî they
    // can't follow a `get()` chain to another doc and then cross-check
    // the caller's identity against it in a single `create` rule.
    match /invites/{token} {

      // GET ‚Äî anyone who knows the token can read the invite.
      // Unauthenticated access is intentional; the token is the secret.
      // This preserves the "share a magic link out-of-band" UX.
      allow get: if true;

      // LIST ‚Äî scoped strictly. A signed-in user can query invites
      // matching THEIR email (inbox) or sent BY them (sent list),
      // and nothing else. Without this clamp, `allow read: if true`
      // let unauthenticated clients dump every invite in the system
      // ‚Äî invitee emails are PII, childIds are secrets used elsewhere,
      // and inviter UIDs shouldn't be harvestable.
      //
      // The `.lower()` on the auth token email is essential: Firebase
      // Auth stores emails in the case the user typed them at signup
      // (so "Bob@Example.com" is valid), but the invite doc's
      // `invitedEmail` is normalised to lowercase at write time
      // (enforced by the sendInvite callable). Without the lower()
      // the inbox breaks for anyone with a mixed-case email.
      allow list: if isSignedIn()
                   && (
                        (resource.data.invitedEmail != null
                          && request.auth.token.email != null
                          && resource.data.invitedEmail ==
                             request.auth.token.email.lower())
                        || resource.data.invitedByUid == request.auth.uid
                      );

      // WRITE ‚Äî denied for all clients. Every mutation on the
      // invites collection goes through a callable:
      //   create  ‚Üí sendInvite   (denormalises childName + inviter
      //                           displayName, lowercases email,
      //                           sets server-side expiresAt)
      //   update  ‚Üí acceptInvite (sets acceptedByUid + acceptedAt
      //                           and arrayUnion's the caller into
      //                           the child's parentUids)
      //   delete  ‚Üí revokeInvite (inviter-only, not-yet-accepted)
      //
      // Centralising all writes behind callables gives us a single
      // trusted code path per operation with consistent validation,
      // denormalisation, and auditability. Direct client writes would
      // have to replicate all of that and would inevitably drift.
      allow write: if false;
    }

    // ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
    // default deny for anything not matched above
    // ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
