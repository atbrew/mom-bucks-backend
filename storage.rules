rules_version = '2';

// PHASE 0 BASELINE — DO NOT SHIP TO PROD UNCHANGED.
//
// Deny-all placeholder. Real per-child / per-user rules arrive alongside
// the Storage cutover in a later phase.
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
