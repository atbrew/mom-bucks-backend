rules_version = '2';

// Storage rules for profile images.
//
// Two paths:
//   users/{uid}/profile.jpg          — user's own profile photo
//   children/{childId}/profile.jpg   — child's profile photo
//
// Upload constraints:
//   - Max 100MB (resize trigger downsizes to ≤5MB server-side)
//   - Image content types only (image/jpeg, image/png, image/webp)
//
// The onProfileImageUpload Cloud Function fires on finalize and:
//   1. Resizes to ≤5MB if needed (overwrites original)
//   2. Updates the photoUrl field on the matching Firestore doc

service firebase.storage {
  match /b/{bucket}/o {

    // ── helpers ──────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isImageType() {
      return request.resource.contentType.matches('image/.*');
    }

    function isUnder100MB() {
      return request.resource.size < 100 * 1024 * 1024;
    }

    // ── users/{uid}/profile.jpg ─────────────────────────────────

    match /users/{uid}/profile.jpg {
      // Only the owning user can read or write their own photo.
      allow read: if isSignedIn()
                  && request.auth.uid == uid;

      allow write: if isSignedIn()
                   && request.auth.uid == uid
                   && isImageType()
                   && isUnder100MB();
    }

    // ── children/{childId}/profile.jpg ──────────────────────────

    match /children/{childId}/profile.jpg {
      // Any parent in parentUids can read or write.
      allow read: if isSignedIn()
                  && request.auth.uid in
                     firestore.get(/databases/(default)/documents/children/$(childId)).data.parentUids;

      allow write: if isSignedIn()
                   && request.auth.uid in
                      firestore.get(/databases/(default)/documents/children/$(childId)).data.parentUids
                   && isImageType()
                   && isUnder100MB();
    }

    // ── default deny ────────────────────────────────────────────

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
